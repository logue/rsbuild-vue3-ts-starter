{
  "name": "rsbuild-vue3-ts-starter",
  "version": "0.1.0",
  "description": "Vue3 Vuetify TypeScript Starter project for Rsbuild.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/rsbuild-vue3-ts-starter",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/rsbuild-vue3-ts-starter.git"
  },
  "bugs": {
    "url": "https://github.com/logue/rsbuild-vue3-ts-starter/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "rsbuild dev --open",
    "lint": "run-s lint:*",
    "lint:eslint": "rslint --fix .",
    "lint:prettier": "prettier \"./**/*.{js,ts,yaml,json,css,sass,scss,htm,html,vue,md}\" -w -u",
    "lint:biome": "biome format --write",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:clean": "rimraf dist",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "build-only": "rsbuild build",
    "type-check": "vue-tsc --build --force",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@rsbuild/core": "^2.0.5",
    "@rsbuild/plugin-vue": "^1.2.8",
    "@rslib/core": "^0.21.4",
    "@rslint/core": "^0.5.2",
    "@rstest/adapter-rsbuild": "^0.2.6",
    "@rstest/core": "^0.9.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^25.6.2",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.8"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": "run-s lint:*"
  },
  "stackblitz": {
    "startCommand": "pnpm run test:unit"
  }
}
